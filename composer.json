{
    "name": "hopekelldev/laravel-paystack",
    "description": "Modern Paystack SDK for Laravel 13 and PHP 8.3+.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Hope Ezenwa (Hopekell Technologies)",
            "email": "ezenwa.hope@hopekelltech.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^12.0",
        "illuminate/http": "^12.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0 || ^12.0"
    },
    "autoload": {
        "psr-4": {
            "HopekellDev\\Paystack\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "HopekellDev\\Paystack\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "HopekellDev\\Paystack\\PaystackServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "coverage": "vendor/bin/phpunit --coverage-clover=coverage.xml",
        "phpcs": "vendor/bin/phpcs --standard=PSR12 src/"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        },
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}